{
  "name": "moimenta84/laraauth",
  "description": "Sistema de autenticación premium para Laravel con OTP, 2FA, social login y componentes Blade publicables.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Iker Martínez",
      "email": "moimenta267@gmail.com",
      "homepage": "https://ikermartinezdev.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0|^12.0|^13.0",
    "laravel/socialite": "^5.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Moimenta84\\LaraAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Moimenta84\\LaraAuth\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Moimenta84\\LaraAuth\\LaraAuthServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
